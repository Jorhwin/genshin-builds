---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props as Props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

      :root {
        --bg-primary: #0a0a12;
        --bg-secondary: #12121e;
        --bg-card: #1a1a2e;
        --bg-card-hover: #222240;
        --border: #2a2a44;
        --text-primary: #f0f0f5;
        --text-secondary: #9898b8;
        --text-muted: #6a6a88;
        --accent: #6080ff;
        --accent-glow: rgba(96, 128, 255, 0.15);
        --pyro: #ff6020;
        --hydro: #2080ff;
        --dendro: #40c040;
        --anemo: #60e0e0;
        --electro: #a040ff;
        --geo: #e0a040;
        --cryo: #80c0ff;
        --tier-s: #ffd700;
        --tier-a: #c0c0c0;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        line-height: 1.7;
        color: var(--text-primary);
        background: var(--bg-primary);
        background-image:
          radial-gradient(ellipse at 20% 20%, rgba(96, 128, 255, 0.03) 0%, transparent 60%),
          radial-gradient(ellipse at 80% 80%, rgba(160, 64, 255, 0.03) 0%, transparent 60%);
        min-height: 100vh;
      }

      .container {
        max-width: 920px;
        margin: 0 auto;
        padding: 0 20px;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding: 16px 0;
        margin-bottom: 32px;
        background: rgba(10, 10, 18, 0.8);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .header-inner {
        max-width: 920px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .header-logo {
        color: var(--text-primary);
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 700;
        background: linear-gradient(135deg, var(--accent), #a040ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .header-logo:hover { opacity: 0.85; }

      .header-nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.85rem;
        margin-left: 20px;
        transition: color 0.2s;
      }

      .header-nav a:hover {
        color: var(--accent);
      }

      h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 8px;
        letter-spacing: -0.5px;
      }

      .subtitle {
        color: var(--text-secondary);
        font-size: 1.05rem;
        margin-bottom: 24px;
      }

      h2 {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 32px 0 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--border);
      }

      h3 {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 20px 0 8px;
      }

      p, li { color: var(--text-secondary); margin-bottom: 8px; }
      ul, ol { padding-left: 20px; margin-bottom: 16px; }
      li { margin-bottom: 4px; }

      a {
        color: var(--accent);
        transition: color 0.2s;
        text-decoration: none;
      }
      a:hover { color: #90b0ff; }

      .tag {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.3px;
      }

      .tag-S { background: rgba(255, 215, 0, 0.12); color: var(--tier-s); border: 1px solid rgba(255, 215, 0, 0.2); }
      .tag-A { background: rgba(192, 192, 192, 0.1); color: var(--tier-a); border: 1px solid rgba(192, 192, 192, 0.15); }
      .tag-pyro { background: rgba(255, 96, 32, 0.1); color: var(--pyro); border: 1px solid rgba(255, 96, 32, 0.15); }
      .tag-hydro { background: rgba(32, 128, 255, 0.1); color: var(--hydro); border: 1px solid rgba(32, 128, 255, 0.15); }
      .tag-dendro { background: rgba(64, 192, 64, 0.1); color: var(--dendro); border: 1px solid rgba(64, 192, 64, 0.15); }
      .tag-anemo { background: rgba(96, 224, 224, 0.1); color: var(--anemo); border: 1px solid rgba(96, 224, 224, 0.15); }
      .tag-electro { background: rgba(160, 64, 255, 0.1); color: var(--electro); border: 1px solid rgba(160, 64, 255, 0.15); }
      .tag-geo { background: rgba(224, 160, 64, 0.1); color: var(--geo); border: 1px solid rgba(224, 160, 64, 0.15); }

      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        transition: all 0.25s ease;
      }

      .card:hover {
        background: var(--bg-card-hover);
        border-color: rgba(96, 128, 255, 0.2);
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
      }

      .stat-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin: 16px 0;
      }

      .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 16px;
        transition: border-color 0.2s;
      }

      .stat-card:hover {
        border-color: rgba(96, 128, 255, 0.15);
      }

      .stat-label {
        font-size: 0.7rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-weight: 600;
        margin-bottom: 4px;
      }

      .stat-value {
        font-size: 0.92rem;
        color: var(--text-primary);
        font-weight: 500;
      }

      .rating-big {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--tier-s);
        background: linear-gradient(135deg, var(--tier-s), #ff8c00);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .insight-box {
        background: linear-gradient(135deg, rgba(96, 128, 255, 0.06), rgba(160, 64, 255, 0.06));
        border: 1px solid rgba(96, 128, 255, 0.15);
        border-radius: 10px;
        padding: 16px 20px;
        margin: 20px 0;
      }

      .insight-box h3 {
        color: var(--accent);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0 0 8px;
        border: none;
        padding: 0;
      }

      .insight-box p {
        color: var(--text-secondary);
        margin: 0;
      }

      .version-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        background: rgba(96, 128, 255, 0.08);
        border: 1px solid rgba(96, 128, 255, 0.12);
        border-radius: 20px;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 16px 0;
      }

      .version-badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #40c040;
        display: inline-block;
      }

      .internal-links {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin: 28px 0;
      }

      .internal-links h3 {
        margin: 0 0 12px;
        color: var(--text-primary);
        font-weight: 700;
        border: none;
        padding: 0;
      }

      .internal-links a {
        display: block;
        padding: 8px 12px;
        margin: 0 -12px;
        border-radius: 6px;
        transition: background 0.2s;
        font-weight: 500;
      }

      .internal-links a:hover {
        background: rgba(96, 128, 255, 0.06);
      }

      .character-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
        list-style: none;
        padding: 0;
        margin: 12px 0;
      }

      .character-list li {
        margin: 0;
      }

      .character-list a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: all 0.2s;
        color: var(--text-primary);
        font-weight: 500;
      }

      .character-list a:hover {
        background: var(--bg-card-hover);
        border-color: rgba(96, 128, 255, 0.2);
        transform: translateX(4px);
      }

      .character-list .desc {
        color: var(--text-muted);
        font-size: 0.82rem;
        font-weight: 400;
        margin-left: auto;
        max-width: 50%;
        text-align: right;
      }

      .mini-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
        margin: 12px 0;
      }

      .mini-grid a {
        display: block;
        padding: 12px 16px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: all 0.2s;
        color: var(--text-primary);
        font-weight: 500;
        font-size: 0.92rem;
      }

      .mini-grid a:hover {
        background: var(--bg-card-hover);
        border-color: rgba(96, 128, 255, 0.2);
      }

      footer {
        border-top: 1px solid var(--border);
        margin-top: 48px;
        padding: 24px 0;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-align: center;
      }

      @media (max-width: 640px) {
        .stat-grid { grid-template-columns: 1fr; }
        h1 { font-size: 1.5rem; }
        .character-list .desc { display: none; }
        .header-nav a { margin-left: 12px; font-size: 0.78rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="header-logo">✦ Genshin Builds</a>
        <nav class="header-nav">
          <a href="/">Characters</a>
          <a href="/">Builds</a>
          <a href="/">Teams</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <p>Genshin Impact Build Guides — Updated for latest version. Not affiliated with HoYoverse.</p>
        <p style="margin-top: 4px; font-size: 0.75rem;">Data sourced from community consensus & KQM.</p>
      </div>
    </footer>
  </body>
</html>