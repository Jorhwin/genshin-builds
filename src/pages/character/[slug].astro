---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { characters } from "../../data/characters";
import { coreInsights } from "../../data/insights";
import { extendedGuides } from "../../data/extended-guides";

export function getStaticPaths() {
  return characters.map((c) => ({
    params: { slug: c.slug },
    props: { character: c },
  }));
}

const { character: c } = Astro.props;
const title = c.name + " Build Guide - Best Weapons and Artifacts 2026";
const description = "Complete " + c.name + " build guide. Best weapon: " + c.bestWeapon + ". Best artifacts: " + c.bestArtifacts + ".";
---

<BaseLayout title={title} description={description}>
  <p>
    <span class={"tag tag-" + c.tier}>{c.tier}</span>
    <span class={"tag tag-" + c.element.toLowerCase()}>{c.element}</span>
    <span style="color: var(--text-muted);">{c.role} &middot; {c.weapon}</span>
  </p>
  <h1>{c.name} Build Guide</h1>
  <p>{c.description}</p>

  {coreInsights[c.slug] && (
    <div class="insight-box">
      <h3>Why This Build Works</h3>
      <p>{coreInsights[c.slug].whyItWorks}</p>
      <h3>Key Stat Threshold</h3>
      <p>{coreInsights[c.slug].keyThreshold}</p>
      <h3>Current Meta Status</h3>
      <p>{coreInsights[c.slug].metaStatus}</p>
    </div>
  )}

  <h2>Gameplay Strategy</h2>
  <div class="card">
    <p>{c.name} functions best as a {c.role}. The key to mastering this character is understanding how their kit interacts with the current abyss meta. Below are the critical gameplay patterns you need to know.</p>
    <h3>Rotation Tips</h3>
    <p>{c.rotation}</p>
    <h3>Team Synergy</h3>
    <p>{c.teamRole} In practice, this means pairing them with characters that complement their strengths and cover their weaknesses.</p>
  </div>

  <h2>Build Comparison: Entry vs Endgame</h2>
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-label">Entry Level Build</div>
      <div class="stat-value">{c.f2pWeapon}</div>
      <p style="margin-top: 4px;">Focus on main stat correctness. Set bonuses matter less than having correct main stats.</p>
    </div>
    <div class="stat-card">
      <div class="stat-label">Endgame Build</div>
      <div class="stat-value">{c.bestWeapon}</div>
      <p style="margin-top: 4px;">Optimize substats for perfect ratio. Sacrifice HP/DEF for more offensive stats.</p>
    </div>
  </div>

  <div class="insight-box" style="margin-top: 20px;">
    <h3>Summary: Is {c.name} Worth Building?</h3>
    <p>{c.description} With the right investment, {c.name} performs at a <strong>{c.rating}</strong> level in current content.</p>
  </div>

  {coreInsights[c.slug] && coreInsights[c.slug].weakness && (
    <div class="card" style="border-color:rgba(255,96,32,0.2);">
      <h3 style="color:#ff6020;">When NOT to use this character</h3>
      <p>{coreInsights[c.slug].weakness}</p>
    </div>
  )}

  {coreInsights[c.slug] && coreInsights[c.slug].controversy && (
    <div class="card" style="border-color:rgba(255,215,0,0.2);">
      <h3 style="color:#ffd700;">Community Controversy</h3>
      <p>{coreInsights[c.slug].controversy}</p>
    </div>
  )}

  {extendedGuides[c.slug] && (
    <div class="card" style="margin: 20px 0; border-color: rgba(96,128,255,0.15);">
      <h3 style="color: var(--accent);">In-Depth Guide</h3>
      <div style="white-space: pre-line; line-height: 1.8;">{extendedGuides[c.slug].guide}</div>
    </div>
  )}

  <div class="version-badge">Updated for Version 5.x</div>
  <h2>Best Build Overview</h2>
  <div class="stat-grid">
    {['bestWeapon','f2pWeapon','bestArtifacts','mainStats','subStats','talentPriority'].map(key => (
      <div class="stat-card">
        <div class="stat-label">{key.replace(/([A-Z])/g," $1").trim()}</div>
        <div class="stat-value">{c[key]}</div>
      </div>
    ))}
  </div>
  <h2>Team Role</h2>
  <p>{c.teamRole}</p>
  <h2>Rotation Guide</h2>
  <p>{c.rotation}</p>
  <div class="internal-links">
    <h3>More {c.name} Guides</h3>
    <a href={"/build/" + c.slug + "/"}>{c.name} Best Build Guide</a>
    <a href={"/team/" + c.slug + "/"}>{c.name} Best Team Guide</a>
  </div>
</BaseLayout>