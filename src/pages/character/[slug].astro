---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { characters } from "../../data/characters";
import { coreInsights } from "../../data/insights";

export function getStaticPaths() {
  return characters.map((c) => ({
    params: { slug: c.slug },
    props: { character: c },
  }));
}

const { character: c } = Astro.props;
const title = c.name + " Build Guide - Best Weapons and Artifacts 2026";
const description = "Complete " + c.name + " build guide. Best weapon: " + c.bestWeapon + ". Best artifacts: " + c.bestArtifacts + ".";
---

<BaseLayout title={title} description={description}>
  <p>
    <span class={"tag tag-" + c.tier}>{c.tier}</span>
    <span class={"tag tag-" + c.element.toLowerCase()}>{c.element}</span>
    <span style="color: var(--text-muted);">{c.role} &middot; {c.weapon}</span>
  </p>
  <h1>{c.name} Build Guide</h1>
  <p>{c.description}</p>

  {coreInsights[c.slug] && (
    <div class="insight-box">
      <h3>Why This Build Works</h3>
      <p>{coreInsights[c.slug].whyItWorks}</p>
      <h3>Key Stat Threshold</h3>
      <p>{coreInsights[c.slug].keyThreshold}</p>
      <h3>Current Meta Status</h3>
      <p>{coreInsights[c.slug].metaStatus}</p>
    </div>
  )}

  {coreInsights[c.slug] && coreInsights[c.slug].weakness && (
    <div class="card" style="border-color:rgba(255,96,32,0.2);">
      <h3 style="color:#ff6020;">When NOT to use this character</h3>
      <p>{coreInsights[c.slug].weakness}</p>
    </div>
  )}

  {coreInsights[c.slug] && coreInsights[c.slug].controversy && (
    <div class="card" style="border-color:rgba(255,215,0,0.2);">
      <h3 style="color:#ffd700;">Community Controversy</h3>
      <p>{coreInsights[c.slug].controversy}</p>
    </div>
  )}

  <div class="version-badge">Updated for Version 5.x</div>
  <h2>Best Build Overview</h2>
  <div class="stat-grid">
    {['bestWeapon','f2pWeapon','bestArtifacts','mainStats','subStats','talentPriority'].map(key => (
      <div class="stat-card">
        <div class="stat-label">{key.replace(/([A-Z])/g," $1").trim()}</div>
        <div class="stat-value">{c[key]}</div>
      </div>
    ))}
  </div>
  <h2>Team Role</h2>
  <p>{c.teamRole}</p>
  <h2>Rotation Guide</h2>
  <p>{c.rotation}</p>
  <div class="internal-links">
    <h3>More {c.name} Guides</h3>
    <a href={"/build/" + c.slug + "/"}>{c.name} Best Build Guide</a>
    <a href={"/team/" + c.slug + "/"}>{c.name} Best Team Guide</a>
  </div>
</BaseLayout>